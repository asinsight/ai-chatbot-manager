# ═══════════════════════════════════════════
# LLM 서버 설정
# ═══════════════════════════════════════════
# LLM API 엔드포인트 (llama-cpp-python 또는 Open WebUI)
OPENWEBUI_URL=http://localhost:8080
# LLM API 키 (llama-cpp-python은 빈 문자열)
OPENWEBUI_API_KEY=
# LLM API 경로 (/v1/chat/completions 또는 /api/chat/completions)
LLM_API_PATH=/v1/chat/completions
# 사용할 모델명 (llama-cpp-python: 모델 파일 경로)
MODEL_NAME=

# ═══════════════════════════════════════════
# Grok API (이미지 태그 생성 + 요약)
# ═══════════════════════════════════════════
GROK_API_KEY=
GROK_MODEL_NAME=grok-3-mini

# ═══════════════════════════════════════════
# ComfyUI (이미지 생성)
# ═══════════════════════════════════════════
# ComfyUI API 엔드포인트
COMFYUI_URL=http://localhost:8188
# ComfyUI 큐 최대 허용 수 (초과 시 요청 거절, 기본 10)
#COMFYUI_MAX_QUEUE=10
# ComfyUI stuck 판정 시간 초 (기본 360 = 6분)
#COMFYUI_STUCK_TIMEOUT=360
# ComfyUI VRAM 최소 여유량 MB (이 아래로 떨어지면 Admin 경고, 기본 20)
#COMFYUI_VRAM_MIN_MB=20

# ═══════════════════════════════════════════
# 비디오 생성 (Atlas Cloud)
# ═══════════════════════════════════════════
# 비디오 모델 (기본 alibaba/wan-2.6/image-to-video-flash — Atlas Cloud SFW 기본 + 네이티브 오디오 지원)
#VIDEO_MODEL=alibaba/wan-2.6/image-to-video-flash

# ═══════════════════════════════════════════
# 메모리 / 요약
# ═══════════════════════════════════════════
# 요약 트리거 메시지 수 (기본 20)
#SUMMARY_THRESHOLD=20
# 요약 시 원문 유지할 최근 메시지 수 (기본 10)
#RECENT_MESSAGES_KEEP=10

# ═══════════════════════════════════════════
# 이미지 자율 전송 (0=거의 안보냄, 1=가끔, 2=종종, 3=자주)
# ═══════════════════════════════════════════
# fixation 기반 자동 조정: fixation < 20 → 0으로 강제, fixation > 80 → 한 단계 상향
#IMAGE_AUTONOMY=1

# ═══════════════════════════════════════════
# 씬 강제 (디버그용)
# ═══════════════════════════════════════════
# 특정 SFW 씬 키를 강제로 사용 (옵션, 빈 값이면 정상 랜덤 선택)
#FORCE_SFW_SCENE=

# ═══════════════════════════════════════════
# 환경 선택 (test / prod)
# ═══════════════════════════════════════════
# ENV에 따라 {ENV}_MAIN_BOT_TOKEN → MAIN_BOT_TOKEN 으로 자동 매핑
ENV=test

# ═══════════════════════════════════════════
# 봇 토큰 — Test 환경 (TEST_ 접두사)
# ═══════════════════════════════════════════
TEST_MAIN_BOT_TOKEN=
TEST_MAIN_BOT_USERNAME=
#TEST_CHAR_BOT_char06=
#TEST_CHAR_USERNAME_char06=

# ═══════════════════════════════════════════
# 봇 토큰 — Prod 환경 (PROD_ 접두사)
# ═══════════════════════════════════════════
PROD_MAIN_BOT_TOKEN=
PROD_MAIN_BOT_USERNAME=
#PROD_CHAR_BOT_char01=
#PROD_CHAR_BOT_char02=
# ...
#PROD_CHAR_USERNAME_char01=
#PROD_CHAR_USERNAME_char02=
# ...

# ═══════════════════════════════════════════
# 티어 / 결제 설정
# ═══════════════════════════════════════════
# Free 유저가 이용 가능한 캐릭터 (콤마 구분, 기본 char06)
#FREE_CHAR_IDS=char06
# Free 유저 일일 최대 턴 수 (기본 20, 자정 리셋)
#FREE_MAX_TURNS=20
# Free 유저 월 이미지 제한 (기본 2, 0=완전 차단)
#FREE_MAX_IMAGES=2
# Standard 월 이미지 제한 (기본 30)
#STANDARD_MAX_IMAGES=30
# Standard 일 이미지 제한 (기본 5)
#STANDARD_DAILY_IMAGES=5
# Premium 월 이미지 제한 (기본 60)
#PREMIUM_MAX_IMAGES=60
# Premium 일 이미지 제한 (기본 10)
#PREMIUM_DAILY_IMAGES=10
# 구독 가격 (Stars)
#STANDARD_STARS=250
#PREMIUM_STARS=700
# 구독 기간 (일)
#STANDARD_DAYS=30
#PREMIUM_DAYS=30

# ═══════════════════════════════════════════
# LLM 큐 설정
# ═══════════════════════════════════════════
# 동시 LLM 호출 최대 수 (기본 2)
#LLM_MAX_CONCURRENT=2
# 큐 최대 대기 수 (기본 20)
#LLM_MAX_QUEUE_SIZE=20
# 큐 대기 타임아웃 초 (기본 120)
#LLM_QUEUE_TIMEOUT=120

# ═══════════════════════════════════════════
# Admin
# ═══════════════════════════════════════════
# Admin 유저 ID (콤마 구분)
ADMIN_USER_IDS=
# Admin 알림 on/off (1=켜짐, 0=꺼짐, 기본 1)
#ADMIN_NOTIFY=1

# ═══════════════════════════════════════════
# 로깅
# ═══════════════════════════════════════════
# 로그 레벨 (INFO / DEBUG)
#LOG_LEVEL=INFO
