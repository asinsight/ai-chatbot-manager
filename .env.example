# ═══════════════════════════════════════════
# LLM server
# ═══════════════════════════════════════════
# LLM API endpoint (llama-cpp-python or Open WebUI)
OPENWEBUI_URL=http://localhost:8080
# LLM API key (empty string for llama-cpp-python)
OPENWEBUI_API_KEY=
# LLM API path (/v1/chat/completions or /api/chat/completions)
LLM_API_PATH=/v1/chat/completions
# Model name (for llama-cpp-python: absolute path to model file)
MODEL_NAME=

# ═══════════════════════════════════════════
# Grok API (image tag generation + summarization)
# ═══════════════════════════════════════════
GROK_API_KEY=
# Default model — fallback for every Grok call (used unless overridden below)
GROK_PROMPTING_MODEL=grok-3-mini
# Grok base URL (defaults to X.AI; change when using an OpenAI-compatible proxy)
#GROK_BASE_URL=https://api.x.ai/v1
# Image-related calls override — Danbooru tags / random / classify / partial_edit
#GROK_PROMPTING_IMAGE_MODEL=
# Video-related calls override — analyze_video_scene + motion prompt assembly
#GROK_PROMPTING_VIDEO_MODEL=
# video_analyzer-only override (Stage 1 i2v scene analyzer; wins over GROK_PROMPTING_VIDEO_MODEL)
#GROK_PROMPTING_VIDEO_ANALYZER_MODEL=
# video_composer-only override (Stage 2 motion-prompt composer; wins over GROK_PROMPTING_VIDEO_MODEL)
#GROK_PROMPTING_VIDEO_COMPOSER_MODEL=
# Grok web-search (grok_search.py) dedicated model
#GROK_PROMPTING_SEARCH_MODEL=

# ═══════════════════════════════════════════
# ComfyUI (image generation)
# ═══════════════════════════════════════════
# ComfyUI API endpoint
COMFYUI_URL=http://localhost:8188
# Max queued ComfyUI jobs allowed (excess is rejected; default 10)
#COMFYUI_MAX_QUEUE=10
# ComfyUI stuck timeout in seconds (default 360 = 6 min)
#COMFYUI_STUCK_TIMEOUT=360
# Minimum free ComfyUI VRAM in MB (admin warning fires below this; default 20)
#COMFYUI_VRAM_MIN_MB=20
# Workflow JSON path used for Standard-stage renders (default: comfyui_workflow/main_character_build.json)
#COMFYUI_WORKFLOW=
# Workflow JSON path used for HQ-stage renders when /hq on (default: comfyui_workflow/main_character_build_highqual.json)
#COMFYUI_WORKFLOW_HQ=

# ═══════════════════════════════════════════
# Video generation (Atlas Cloud)
# ═══════════════════════════════════════════
# Video model (default alibaba/wan-2.6/image-to-video-flash — Atlas Cloud SFW default + native audio support)
#VIDEO_MODEL=alibaba/wan-2.6/image-to-video-flash

# ═══════════════════════════════════════════
# Memory / summarization
# ═══════════════════════════════════════════
# Message count that triggers summarization (default 20)
#SUMMARY_THRESHOLD=20
# Recent messages kept verbatim during summarization (default 10)
#RECENT_MESSAGES_KEEP=10

# ═══════════════════════════════════════════
# Autonomous image sending (0=almost never, 1=rare, 2=often, 3=frequent)
# ═══════════════════════════════════════════
# Fixation-based auto adjust: fixation < 20 → forced 0; fixation > 80 → bumped one tier up
#IMAGE_AUTONOMY=1

# ═══════════════════════════════════════════
# Scene override (debug only)
# ═══════════════════════════════════════════
# Force a specific SFW scene key (optional; blank = normal random selection)
#FORCE_SFW_SCENE=

# ═══════════════════════════════════════════
# Bot tokens
# ═══════════════════════════════════════════
# Main onboarding bot — get the token + username from @BotFather
MAIN_BOT_TOKEN=
MAIN_BOT_USERNAME=
# Per-character bot tokens (replace charNN with the actual character id; duplicate the line per character)
#CHAR_BOT_charNN=
#CHAR_USERNAME_charNN=
# Image-generator bot
#CHAR_BOT_imagegen=
#CHAR_USERNAME_imagegen=

# ═══════════════════════════════════════════
# LLM queue
# ═══════════════════════════════════════════
# Max concurrent LLM calls (default 2)
#LLM_MAX_CONCURRENT=2
# Max queued LLM requests (default 20)
#LLM_MAX_QUEUE_SIZE=20
# Queue wait timeout in seconds (default 120)
#LLM_QUEUE_TIMEOUT=120

# ═══════════════════════════════════════════
# Prompt Guard (injection-detection service)
# ═══════════════════════════════════════════
# Prompt Guard API URL (POST /check endpoint for verification)
#PROMPT_GUARD_URL=http://192.168.86.250:8081
# Block threshold (0.0 ~ 1.0; default 0.8)
#PROMPT_GUARD_THRESHOLD=0.8

# ═══════════════════════════════════════════
# Admin
# ═══════════════════════════════════════════
# Admin user IDs (comma-separated)
ADMIN_USER_IDS=
# Admin notifications on/off (1=on, 0=off; default 1)
#ADMIN_NOTIFY=1

# ═══════════════════════════════════════════
# Logging
# ═══════════════════════════════════════════
# Log level (INFO / DEBUG)
#LOG_LEVEL=INFO

# ═══════════════════════════════════════════
# Admin webapp (platform/) — bot lifecycle control
# ═══════════════════════════════════════════
# Python interpreter used to spawn the bot process (absolute path recommended).
# Empty / unset → uses 'python3' on PATH (will hit ImportError if your venv isn't activated).
#PYTHON_BIN=/Users/junheeyoon/Code/ella-chat-publish/venv/bin/python
